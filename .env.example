# ── Genesys Cloud ─────────────────────────────────────────────────────────────
# OAuth 2.0 Client Credentials (Admin > Integrations > OAuth)
GENESYS_CLIENT_ID=your-client-id
GENESYS_CLIENT_SECRET=your-client-secret
GENESYS_REGION=us-east-1

# Open Messaging integration UUID (Admin > Messaging > Open Messaging)
GENESYS_OPEN_MESSAGING_INTEGRATION_ID=your-integration-id

# ── A2A Bridge Server ─────────────────────────────────────────────────────────
PORT=3000
AGENT_NAME="Genesys AVA"
AGENT_DESCRIPTION="Genesys Cloud Agentic Virtual Agent connected to an Architect Bot Flow"

# Public base URL of this server — included in the Agent Card so callers know
# where to send tasks (no trailing slash)
AGENT_BASE_URL=https://your-a2a-server.example.com

# How long (ms) to wait for the AVA to respond before failing the task
RESPONSE_TIMEOUT_MS=30000

# ── Authentication ────────────────────────────────────────────────────────────
# At least one of the following blocks must be configured before exposing
# this server publicly. Both can be active simultaneously.

# Option A — OIDC Bearer token (recommended for agent-to-agent trust)
# Callers present: Authorization: Bearer <jwt>
# The JWT must be issued by OIDC_ISSUER and signed with a key in its JWKS.
# OIDC_ISSUER is also used to construct the JWKS URI:
#   ${OIDC_ISSUER}/.well-known/jwks.json
#
# Common values:
#   Google:   https://accounts.google.com
#   Okta:     https://<your-domain>.okta.com
#   Azure AD: https://login.microsoftonline.com/<tenant-id>/v2.0
OIDC_ISSUER=https://accounts.google.com
OIDC_AUDIENCE=your-client-id-or-api-identifier

# Option B — Static API key (simpler; suitable for trusted internal callers)
# Callers present: x-api-key: <key>
# Comma-separated list of allowed keys. Values may be raw strings or
# pre-hashed SHA-256 hex digests (recommended for storage security).
# Generate a key:  openssl rand -hex 32
# Hash a key:      echo -n "your-key" | sha256sum
A2A_API_KEYS=your-secret-key-1,your-secret-key-2
